# ============================================================
# LLM Configuration (Groq + Qwen)
# ============================================================
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL_NAME=qwen-3-32b

# ============================================================
# Paper Search APIs
# ============================================================
# ArXiv: No API key needed (free), but we rate-limit ourselves
ARXIV_MAX_RESULTS=20
ARXIV_TIMEOUT_SECONDS=10

# Semantic Scholar: Free API, no auth key for basic queries
SEMANTIC_SCHOLAR_TIMEOUT_SECONDS=10

# ============================================================
# LangSmith (Tracing & Evaluation)
# ============================================================
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=research-agent-dev
LANGSMITH_TRACING_V2=true

# ============================================================
# Agent Configuration
# ============================================================
MAX_ITERATIONS=5
CONTEXT_WINDOW_LIMIT=120000

# ============================================================
# Database (Checkpointing for HITL)
# ============================================================
CHECKPOINT_DB_PATH=./research_agent.db

# ============================================================
# API Server (for MODULE 13)
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000